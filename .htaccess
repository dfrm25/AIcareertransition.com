# AI Career Transition — caching & compression (Apache / cPanel)
# Improves PageSpeed "efficient cache" for css, js, images.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical SEO host: force HTTPS and non-www.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.aicareertransition\.com$ [NC]
  RewriteRule ^(.*)$ https://aicareertransition.com/$1 [R=301,L]

  # Consolidate /index.html variants to the directory root.
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
  RewriteRule ^(.*/)?index\.html$ https://aicareertransition.com/$1 [R=301,L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Long cache for fingerprint-free static assets; redeploy or rename files to bust cache.
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(svg|png|jpg|jpeg|webp|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # HTML should revalidate so deploys show up quickly
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>
